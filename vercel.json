{
  "version": 2,
  "routes": [
    { "src": "/order$", "dest": "/order/" },
    { "src": "/order-confirmed$", "dest": "/order-confirmed/" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
