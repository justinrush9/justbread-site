{
  "version": 2,
  "builds": [
    { "src": "api/checkout.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/checkout.js" },
    { "src": "/order", "dest": "/order/index.html" },
    { "src": "/order/", "dest": "/order/index.html" },
    { "src": "/order-confirmed", "dest": "/order-confirmed/index.html" },
    { "src": "/order-confirmed/", "dest": "/order-confirmed/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
