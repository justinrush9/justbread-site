{
  "version": 2,
  "rewrites": [
    { "source": "/order", "destination": "/order/index.html" },
    { "source": "/order/", "destination": "/order/index.html" },
    { "source": "/order-confirmed", "destination": "/order-confirmed/index.html" },
    { "source": "/order-confirmed/", "destination": "/order-confirmed/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
